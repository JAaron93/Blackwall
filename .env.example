# =============================================================================
# Blackwall Agentic Firewall — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values. Never commit .env to git.
# All variables are required unless marked [OPTIONAL].
# =============================================================================


# -----------------------------------------------------------------------------
# Blackwall Operation Mode (Free vs. Paid Tier)
# -----------------------------------------------------------------------------
# Controls whether Blackwall uses free-tier (15 RPM, synchronous) or paid-tier
# (300 RPM, async batching) Gemini API mode.
#
# Valid values: "free" | "paid"
# Default: "free" (judge-friendly, zero-friction reproduction)
#
# FREE TIER (15 RPM):
#   - Synchronous single-request evaluation via client.models.generate_content()
#   - No async batching, no InterceptionQueue, no webhook listener
#   - Signature generation happens inline (adds ~200-500ms latency per BLOCK)
#   - All core security mechanisms intact: hybrid gating, self-learning, audit hooks
#   - Eval suite takes ~8-10 minutes for 120 test cases
#
# PAID TIER (300 RPM):
#   - Asynchronous batched evaluation via client.interactions.create()
#   - Server-side context caching (50%+ token cost reduction)
#   - Background webhook-driven signature generation (zero added latency)
#   - Eval suite takes ~40 seconds for 120 test cases
#
# For Kaggle judges: Leave this as "free" for zero-friction reproduction.
# For performance benchmarking: Set to "paid" to see full throughput capabilities.
# -----------------------------------------------------------------------------
BLACKWALL_TIER=free


# -----------------------------------------------------------------------------
# Gemini API (Blackwall Agent)
# Required for semantic gating, behavioral evaluation, and the Hermes loop.
# Get your key at: https://aistudio.google.com/app/apikey
#
# NOTE: Free tier (15 RPM) requires NO payment setup. Paid tier (300 RPM)
# requires billing enabled at https://console.cloud.google.com/billing
# -----------------------------------------------------------------------------
GEMINI_API_KEY=

# Model used by Blackwall's semantic reasoning engine
# Use gemini-3.1-flash-lite (fastest)
# Paid tier: Use gemini-3.5-flash or gemini-3.1-pro (best quality)
BLACKWALL_MODEL=gemini-3.1-flash-lite

# RPM cap for your API tier (used by rate limiter)
# Free tier: 15 RPM (enforced by SyncResolver)
# Paid tier: 300 RPM (enforced by BatchResolver token bucket)
GEMINI_RPM_LIMIT=15


# -----------------------------------------------------------------------------
# Gemini Embedding API (gemini-embedding-001)
# Used for threat signature similarity vector generation (768-dim).
# Shares the same GEMINI_API_KEY above — no separate key required.
# Called exclusively in the async Tier 3 webhook flow (never in <10ms path).
# Docs: https://ai.google.dev/gemini-api/docs/embeddings
# -----------------------------------------------------------------------------
# Embedding model name (do not change — 768-dim output is hardcoded in spec)
EMBEDDING_MODEL=gemini-embedding-001

# Output vector dimensionality — must match embeddingDimension in policy YAML
EMBEDDING_DIMENSION=768

# Timeout (ms) for embedding API calls before falling back to FTS5 search
EMBEDDING_TIMEOUT_MS=5000


# -----------------------------------------------------------------------------
# Hyperbolic API (Adversarial Red-Teamer)
# Used only in the dual-agent sandbox demo. Not needed in production.
# Get your key at: https://app.hyperbolic.xyz
# -----------------------------------------------------------------------------
HYPERBOLIC_API_KEY=

# Red-Teamer model (Qwen3-Coder 480B via Hyperbolic)
REDTEAM_MODEL=Qwen/Qwen3-Coder-480B-A35B-Instruct

# Red-Teamer RPM ceiling (demo harness enforces this as a rate cap)
REDTEAM_RPM_LIMIT=600


# -----------------------------------------------------------------------------
# Google Threat Intelligence (GTI) MCP Server
# Live IOC lookups via VirusTotal / GTI during before_tool_callback intercepts.
# Docs: https://cloud.google.com/threat-intelligence
# -----------------------------------------------------------------------------
GTI_MCP_API_KEY=

# Base URL for the GTI MCP server (override for local mock in tests)
GTI_MCP_BASE_URL=https://gti.googleapis.com/v1

# [OPTIONAL] Timeout for GTI IOC queries (ms). Default: 3000
GTI_QUERY_TIMEOUT_MS=3000


# -----------------------------------------------------------------------------
# SQLite Threat Signature Graph
# WAL-mode database storing learned threat signatures and semantic edges.
# -----------------------------------------------------------------------------
# Absolute or relative path to the SQLite database file
BLACKWALL_DB_PATH=./blackwall.db

# Max concurrent SQLite connections in the async pool
DB_MAX_CONNECTIONS=10

# Signature eviction policy: "TTL" or "LFU"
DB_EVICTION_POLICY=LFU

# TTL eviction: max age of a signature in seconds (default: 7 days)
DB_SIGNATURE_TTL_SECONDS=604800

# LFU eviction: minimum match count a signature must have to survive pruning
DB_LFU_MIN_MATCH_COUNT=2

# Target max graph query latency in milliseconds (alert threshold)
DB_MAX_QUERY_TIME_MS=10


# -----------------------------------------------------------------------------
# Encrypted Credential Vault (Zero Ambient Authority)
# Master key for encrypting/decrypting vault/secrets.enc — the local encrypted
# store holding JIT-fetched API credentials. Generate with:
# python3 -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------------------
BLACKWALL_VAULT_KEY=


# -----------------------------------------------------------------------------
# Asynchronous Batch Resolver
# Holds paused ADK before_tool_callback threads until a batch is ready to
# dispatch to Gemini, then maps verdicts back to their originating threads.
# -----------------------------------------------------------------------------
# Number of intercepted requests to accumulate before dispatching a batch
BATCH_SIZE=5

# Max time (ms) to wait for a full batch before flushing a partial one.
# Prevents deadlocks during low-traffic periods.
BATCH_MAX_WAIT_MS=500

# [OPTIONAL] Max simultaneous in-flight batches toward Gemini
BATCH_MAX_CONCURRENT=3


# -----------------------------------------------------------------------------
# Hybrid Policy Server
# -----------------------------------------------------------------------------
# Path to the structural YAML policy file (fast-path denylist + role config)
POLICY_CONFIG_PATH=./config/policy_template.yaml

# Semantic gating: score threshold above which a request is auto-blocked
# without waiting for batch processing (0.0–1.0)
SEMANTIC_BLOCK_THRESHOLD=0.85

# Fallback action when the Gemini API is unreachable: BLOCK or QUARANTINE
SEMANTIC_FALLBACK_ACTION=BLOCK


# -----------------------------------------------------------------------------
# Context Hygiene / ContextResolver Middleware
# Regex-based PII/secret redaction applied to all payloads before Gemini sees them.
# -----------------------------------------------------------------------------
# Enable/disable context hygiene middleware (true/false)
CONTEXT_HYGIENE_ENABLED=true

# Max time (ms) allowed for the redaction pass before failing open
CONTEXT_HYGIENE_TIMEOUT_MS=100


# -----------------------------------------------------------------------------
# Behavioral Evaluation (LLM-as-Judge)
# Drift scoring matrix (0–5) applied to security events.
# -----------------------------------------------------------------------------
# Max allowed drift score before an agent session is quarantined
BEHAVIORAL_DRIFT_TOLERANCE=2.0

# [OPTIONAL] Number of recent events to include in the drift scoring window
BEHAVIORAL_SCORING_WINDOW=10


# -----------------------------------------------------------------------------
# Runtime Audit Hook (Sandbox only)
# sys.addaudithook enforcement for the Kali Linux VM demo environment.
# Set AUDIT_HOOK_ENABLED=false in CI to avoid interfering with the test runner.
# -----------------------------------------------------------------------------
AUDIT_HOOK_ENABLED=true

# Comma-separated list of blocked audit event prefixes
AUDIT_BLOCKED_EVENTS=subprocess,os.exec,socket.connect,open


# -----------------------------------------------------------------------------
# Webhook / HTTP Server (Gemini Interactions API callbacks)
# Receives thin-payload Standard Webhooks envelopes when background
# interactions complete. JWT/JWKS (RS256) signature verification enforced.
# -----------------------------------------------------------------------------
BLACKWALL_WEBHOOK_PORT=8090

# JWKS endpoint for fetching Google's public keys (RS256 verification)
# Default points to Gemini's published JWKS endpoint — override for testing only
GEMINI_JWKS_URL=https://generativelanguage.googleapis.com/.well-known/jwks.json

# JWT audience claim validation (required for webhook security)
# Set this to your project ID or the audience value Gemini embeds in webhook JWTs
# Check https://ai.google.dev/gemini-api/docs/interactions#webhook-security
GEMINI_WEBHOOK_AUDIENCE=


# -----------------------------------------------------------------------------
# Logging & Observability
# -----------------------------------------------------------------------------
# Structured log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Enable JSON log output (true) or human-readable text (false)
LOG_JSON=true

# Enable telemetry/analytics collection (mirrors policy_template.yaml toggle)
TELEMETRY_ENABLED=true


# -----------------------------------------------------------------------------
# Evaluation Metrics (FRR / Evasion Rate test script)
# Controls the dedicated metrics script that calculates False Positive Rate
# and Evasion Rate at the end of a demo run.
# -----------------------------------------------------------------------------
# Output path for the JSON metrics report
METRICS_OUTPUT_PATH=./reports/eval_metrics.json

# Target max False Positive Rate (%) — sub-10% required per spec
METRICS_TARGET_FPR=10.0

# [OPTIONAL] ADK project / session identifiers for trace correlation
ADK_PROJECT_ID=
ADK_SESSION_ID=
